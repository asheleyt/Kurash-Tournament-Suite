{
  "name": "electron-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prebuild": "node scripts/stop-packaged-app.mjs",
    "start": "electron .",
    "verify:packaged-runtime": "node scripts/verify-packaged-runtime.mjs",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable && npm run verify:packaged-runtime"
  },
  "build": {
    "directories": {
      "output": "build-output"
    },
    "appId": "com.kurashteam.scoreboard",
    "productName": "Kurash Scoreboard",
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": false
    },
    "win": {
      "target": "portable",
      "icon": "../public/app-icon.ico",
      "signAndEditExecutable": false
    },
    "files": [
      "**/*",
      "!dist/**",
      "!build-output/**"
    ],
    "extraResources": [
      {
        "from": "../app",
        "to": "laravel/app"
      },
      {
        "from": "../bootstrap",
        "to": "laravel/bootstrap"
      },
      {
        "from": "../config",
        "to": "laravel/config"
      },
      {
        "from": "../database",
        "to": "laravel/database"
      },
      {
        "from": "../public",
        "to": "laravel/public"
      },
      {
        "from": "../resources",
        "to": "laravel/resources"
      },
      {
        "from": "../routes",
        "to": "laravel/routes"
      },
      {
        "from": "../storage/app",
        "to": "laravel/storage-seed/app"
      },
      {
        "from": "../vendor",
        "to": "laravel/vendor"
      },
      {
        "from": "../artisan",
        "to": "laravel/artisan"
      },
      {
        "from": "../portable/runtime",
        "to": "portable/runtime"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
